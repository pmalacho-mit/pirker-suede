{
  "name": "release",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "codegen:options": "npx tsx scripts/generate-model-details.ts --input ./api/ai/models/index.d.ts --output ./api/ai/models/options.generated.ts --type StreamOptionsByProviderAndModel",
    "codegen:streams": "npx tsx scripts/generate-model-details.ts --input ./api/ai/models/index.d.ts --output ./api/ai/models/streams.generated.ts --type StreamFunctionByProviderAndModel",
    "codegen": "npm run codegen:options && npm run codegen:streams"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/typebox-validator": "^1.1.0",
    "@mariozechner/pi-ai": "^0.60.0",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "@sinclair/typebox": "^0.34.48",
    "@sinclair/typebox-codegen": "^0.11.1",
    "chalk": "^5.6.2",
    "diff": "^8.0.3",
    "extract-zip": "^2.0.1",
    "file-type": "^21.3.3",
    "glob": "^13.0.6",
    "hono": "^4.12.8",
    "ts-morph": "^27.0.2"
  }
}
